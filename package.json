{
  "name": "janvey-os",
  "version": "0.1.0",
  "private": true,
  "description": "Janvey OS MVP backend and Slack integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "tsc -p tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "lint": "eslint .",
    "test:upload-nilfisk": "tsx scripts/test-upload-nilfisk.ts"
  },
  "dependencies": {
    "@slack/bolt": "^3.22.0",
    "@supabase/supabase-js": "^2.50.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.27.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
